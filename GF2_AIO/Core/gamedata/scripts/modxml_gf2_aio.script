function on_xml_read()RegisterScriptCallback("on_xml_read",function(a,b)if a==[[configs\ui\textures_descr\ui_actor_portrets.xml]]then local c={"alva","basti","cheeta","groza","helen","klukai","leva","lind","mosin","nikketa","phaetusa","robella","tina","vector"}for d,e in ipairs(c)do local f=string.format([[configs\ui\textures_descr\ui_icon_gf2_%s.xml]],e)if getFS():exist("$game_config$",f)then b:insertFromXMLFile(f,nil,nil,true)end end;return end;local g={["gameplay\\dialogs_escape.xml"]={"alva","basti","cheeta","groza","helen","klukai","leva","lind","mosin","nikketa","phaetusa","robella","tina","vector"}}local h=g[a]if not h then return end;for d,e in ipairs(h)do local i=string.format([[gameplay\dialogs_gf2_%s.xml]],e)if getFS():exist("$game_config$",i)then b:insertFromXMLFile(i,nil,nil,true)end end end)end